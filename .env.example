# GEMINI_API_KEY / VITE_GEMINI_API_KEY: Required for Gemini AI API generation.
# In AI Studio, automatically injected from user secrets.
# On Vercel, set GEMINI_API_KEY or VITE_GEMINI_API_KEY in Vercel Environment Variables.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# VERCEL_TOKEN: Optional Vercel API Personal Access Token for dynamic 1-Click project & subdomain deployment.
VERCEL_TOKEN="YOUR_VERCEL_PERSONAL_ACCESS_TOKEN"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

